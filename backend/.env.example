RAG_ENV=dev
RAG_LOG_LEVEL=INFO
RAG_APP_NAME=Agentic RAG
RAG_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/agentic_rag
RAG_VECTOR_DIM=1536
RAG_VECTOR_DISTANCE_METRIC=cosine
RAG_DEFAULT_CHUNK_SIZE=512
RAG_DEFAULT_CHUNK_OVERLAP=64
RAG_DEFAULT_TOP_K=10
RAG_DEFAULT_SCORE_THRESHOLD=0.25
RAG_EVIDENCE_MIN_CITATIONS=1
RAG_EVIDENCE_MIN_SCORE=0.30
RAG_DEFAULT_EMBEDDING_MODEL=deterministic-local-v1
RAG_REQUEST_TIMEOUT_SECONDS=10
RAG_REQUEST_RETRY_ATTEMPTS=2

RAG_CORS_ALLOWED_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
RAG_CORS_ALLOWED_METHODS=["GET","POST","PUT","PATCH","DELETE","OPTIONS"]
RAG_CORS_ALLOWED_HEADERS=["*"]
RAG_AGENT_MAX_STEPS=12
RAG_AGENT_MAX_REWRITES=2
RAG_AGENT_RERANK_TOP_N=5
RAG_AGENT_QUERY_MIN_CHARS=2
RAG_AGENT_MIN_EVIDENCE_RESULTS=1
RAG_AGENT_CONFLICT_SCORE_DELTA=0.05
