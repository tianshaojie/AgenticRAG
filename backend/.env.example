RAG_ENV=dev
RAG_LOG_LEVEL=INFO
RAG_APP_NAME=Agentic RAG
# Local PostgreSQL defaults (non-docker). Replace `your_local_user` if needed.
RAG_DATABASE_URL=postgresql+psycopg://your_local_user@127.0.0.1:5432/agentic_rag_dev
RAG_TEST_DATABASE_URL=postgresql+psycopg://your_local_user@127.0.0.1:5432/agentic_rag_test
RAG_VECTOR_DIM=1536
RAG_VECTOR_DISTANCE_METRIC=cosine
RAG_DEFAULT_CHUNK_SIZE=512
RAG_DEFAULT_CHUNK_OVERLAP=64
RAG_DEFAULT_TOP_K=10
RAG_DEFAULT_SCORE_THRESHOLD=0.25
RAG_EVIDENCE_MIN_CITATIONS=1
RAG_EVIDENCE_MIN_SCORE=0.30
RAG_DEFAULT_EMBEDDING_MODEL=deterministic-local-v1
RAG_REQUEST_TIMEOUT_SECONDS=10
RAG_REQUEST_RETRY_ATTEMPTS=2
RAG_PROVIDER_BACKOFF_BASE_MS=100
RAG_PROVIDER_BACKOFF_MAX_MS=1000
RAG_EMBEDDING_TIMEOUT_SECONDS=8
RAG_EMBEDDING_RETRY_ATTEMPTS=2
RAG_RETRIEVAL_TIMEOUT_SECONDS=8
RAG_RETRIEVAL_RETRY_ATTEMPTS=2
RAG_RERANK_TIMEOUT_SECONDS=6
RAG_RERANK_RETRY_ATTEMPTS=1
RAG_GENERATION_TIMEOUT_SECONDS=8
RAG_GENERATION_RETRY_ATTEMPTS=1
RAG_RERANKER_PROVIDER=http
RAG_RERANKER_API_KEY=your_reranker_api_key_here
RAG_RERANKER_BASE_URL=
# If you have a full endpoint URL, put it in RAG_RERANKER_ENDPOINT directly.
# If you only have base URL, set RAG_RERANKER_BASE_URL and use path-style endpoint like /v1/rerank.
RAG_RERANKER_ENDPOINT=
RAG_RERANKER_MODEL=qwen3-reranker-8b
RAG_RERANKER_TIMEOUT_SECONDS=8
RAG_RERANKER_MAX_RETRIES=2
RAG_RERANKER_TOP_N=5
RAG_RERANKER_APP_CODE=chatbi_reranker
RAG_RERANKER_APP_NAME=妙查-重排
RAG_RERANKER_INSTRUCT=Please rerank the documents based on the query.
RAG_ENABLE_REAL_RERANKER_PROVIDER=false
RAG_ENABLE_RERANKING=true
RAG_LLM_PROVIDER=openai_compatible
RAG_LLM_API_KEY=your_api_key_here
RAG_LLM_BASE_URL=
# If you have full endpoint URL, put it in RAG_LLM_ENDPOINT directly (recommended for current provider).
# If you have base URL only, set RAG_LLM_BASE_URL and use path-style RAG_LLM_ENDPOINT like /v1/chat/completions.
RAG_LLM_ENDPOINT=https://agent.cnht.com.cn/v1/chat/completions
RAG_LLM_MODEL=gpt-4o-mini
RAG_LLM_TIMEOUT_SECONDS=15
RAG_LLM_MAX_RETRIES=2
RAG_LLM_TEMPERATURE=0.2
RAG_LLM_MAX_TOKENS=512
RAG_ENABLE_REAL_LLM_PROVIDER=false
RAG_EVAL_DATASET_DIR=../evals/golden
RAG_EVAL_DEFAULT_DATASET=golden_v1
RAG_EVAL_MAX_UNSUPPORTED_ANSWER_RATE=0.0
RAG_EVAL_WARNING_UNSUPPORTED_ANSWER_RATE=0.05

RAG_CORS_ALLOWED_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
RAG_CORS_ALLOWED_METHODS=["GET","POST","PUT","PATCH","DELETE","OPTIONS"]
RAG_CORS_ALLOWED_HEADERS=["*"]
RAG_AGENT_MAX_STEPS=12
RAG_AGENT_MAX_REWRITES=2
RAG_AGENT_RERANK_TOP_N=5
RAG_AGENT_QUERY_MIN_CHARS=2
RAG_AGENT_MIN_EVIDENCE_RESULTS=1
RAG_AGENT_CONFLICT_SCORE_DELTA=0.30
RAG_AGENT_AVAILABLE_ROUTES=["pgvector","sql","api"]
RAG_AGENT_SQL_ROUTE_PROVIDER=lexical
RAG_AGENT_API_ROUTE_PROVIDER=lexical
RAG_AGENT_RETRIEVAL_STAGNATION_LIMIT=1
RAG_AGENT_RETRIEVAL_MIN_SCORE_GAIN=0.02
RAG_AGENT_FILTER_MIN_SCORE=0.30
RAG_AGENT_MAX_CHUNKS_PER_DOCUMENT=2
